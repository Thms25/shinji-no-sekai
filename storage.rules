rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow read/write if authenticated
      // In production, refine this to:
      // - Artists can read their own tracks
      // - Admins can write
      // For now, authenticated write is needed for the upload component
      allow read, write: if request.auth != null;
    }
  }
}
